  "calculationFormulas": {
    "description": "Формулы расчёта потребности в НЖК",

    "fromCalories": {
      "linoleicAcid": {
        "formula": "(totalKcal * percentLA / 100) / 9",
        "result": "граммы LA в сутки",
        "note": "1 г жира = 9 ккал"
      },
      "alphaLinolenicAcid": {
        "formula": "(totalKcal * percentALA / 100) / 9",
        "result": "граммы ALA в сутки"
      }
    },

    "fromWeight": {
      "linoleicAcid": {
        "formula": "weightKg * mgPerKg / 1000",
        "result": "граммы LA в сутки"
      },
      "alphaLinolenicAcid": {
        "formula": "weightKg * mgPerKg / 1000",
        "result": "граммы ALA в сутки"
      }
    },

    "example": {
      "description": "Пример расчёта для ребёнка 6 мес, 7 кг, 600 ккал/сут",
      "linoleicAcid": {
        "byPercent": "(600 * 3.5 / 100) / 9 = 2.3 г/сут",
        "byWeight": "7 * 350 / 1000 = 2.4 г/сут"
      },
      "alphaLinolenicAcid": {
        "byPercent": "(600 * 0.5 / 100) / 9 = 0.33 г/сут",
        "byWeight": "7 * 55 / 1000 = 0.38 г/сут"
      }
    }
  },

