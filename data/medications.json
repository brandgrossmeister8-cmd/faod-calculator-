{
  "description": "Дозировки препаратов при FAOD",
  "source": "Клинические рекомендации РФ 2024",

  "carnitine": {
    "description": "L-карнитин (левокарнитин)",
    "tradenames": ["Элькар", "Карнитен", "L-карнитин"],
    "forms": ["раствор 300 мг/мл", "капсулы 250/500 мг", "раствор для инъекций 100 мг/мл"],

    "indications": {
      "primary": {
        "diagnoses": ["OCTN2"],
        "description": "Основное патогенетическое лечение при первичном дефиците карнитина"
      },
      "supportive": {
        "diagnoses": ["SCAD", "MCAD", "SCHAD"],
        "description": "Поддерживающая терапия при вторичном дефиците"
      },
      "crisisOnly": {
        "diagnoses": ["CPT1", "CACT", "CPT2", "VLCAD_ASYMPTOMATIC"],
        "description": "Только при остром метаболическом кризе (p/os)"
      },
      "contraindicated": {
        "diagnoses": ["VLCAD_SYMPTOMATIC", "LCHAD", "TFP"],
        "description": "Противопоказан! Может усилить аритмии",
        "ivContraindicated": true
      },
      "notIndicated": {
        "diagnoses": ["GA2"],
        "description": "Не показан при GA2"
      }
    },

    "dosing": {
      "OCTN2": {
        "oral": {
          "standard": {
            "doseMin": 100,
            "doseMax": 200,
            "unit": "мг/кг/сут",
            "frequency": "3 раза в день",
            "maxDailyDose": 3000,
            "maxUnit": "мг/сут"
          },
          "maintenance": {
            "doseMin": 50,
            "doseMax": 100,
            "unit": "мг/кг/сут",
            "note": "После нормализации уровня карнитина в крови"
          }
        },
        "iv": {
          "crisis": {
            "doseMin": 100,
            "doseMax": 200,
            "unit": "мг/кг/сут",
            "note": "В/в при невозможности перорального приёма"
          }
        }
      },
      "secondaryDeficiency": {
        "oral": {
          "doseMin": 50,
          "doseMax": 100,
          "unit": "мг/кг/сут",
          "frequency": "2-3 раза в день",
          "note": "При документированном снижении карнитина"
        }
      },
      "crisisProtocol": {
        "oral": {
          "dose": 100,
          "unit": "мг/кг",
          "frequency": "однократно",
          "note": "Экстренный приём при подозрении на криз"
        }
      }
    },

    "monitoring": {
      "parameters": ["свободный карнитин", "ацилкарнитины", "соотношение AC/FC"],
      "targetFreeCarnitine": {
        "min": 25,
        "max": 50,
        "unit": "мкмоль/л"
      },
      "frequency": "каждые 3-6 месяцев"
    }
  },

  "riboflavin": {
    "description": "Рибофлавин (витамин B2)",
    "tradenames": ["Рибофлавин", "Витамин B2"],
    "forms": ["таблетки 10 мг", "капсулы 100 мг"],

    "indications": {
      "required": {
        "diagnoses": ["GA2"],
        "description": "Патогенетическое лечение при GA2 (рибофлавин-чувствительные формы)"
      },
      "optional": {
        "diagnoses": ["VLCAD", "LCHAD", "TFP"],
        "description": "Может быть полезен как кофактор"
      }
    },

    "dosing": {
      "GA2": {
        "oral": {
          "doseMin": 100,
          "doseMax": 400,
          "unit": "мг/сут",
          "frequency": "1-3 раза в день",
          "note": "Начать с 100 мг/сут, титровать по ответу"
        },
        "infantDose": {
          "doseMin": 10,
          "doseMax": 20,
          "unit": "мг/кг/сут",
          "maxDailyDose": 400,
          "maxUnit": "мг/сут"
        }
      },
      "supportive": {
        "oral": {
          "doseMin": 50,
          "doseMax": 100,
          "unit": "мг/сут",
          "frequency": "1 раз в день"
        }
      }
    },

    "monitoring": {
      "parameters": ["клинический ответ", "ацилкарнитиновый профиль"],
      "responseTime": "2-4 недели",
      "note": "Оценить ответ через 2-4 недели терапии"
    }
  },

  "dha": {
    "description": "Докозагексаеновая кислота (DHA, омега-3)",
    "tradenames": ["DHA", "Омега-3", "Рыбий жир (очищенный)"],
    "forms": ["капсулы", "жидкая форма"],

    "indications": {
      "required": {
        "diagnoses": ["LCHAD", "TFP"],
        "description": "Обязательно для профилактики ретинопатии и нейропатии"
      },
      "optional": {
        "diagnoses": ["VLCAD"],
        "description": "Рекомендуется при симптоматических формах"
      }
    },

    "dosing": {
      "infants": {
        "ageFrom": 0,
        "ageTo": 12,
        "unit": "месяцев",
        "dose": {
          "min": 60,
          "max": 130,
          "unit": "мг/сут"
        },
        "note": "Может входить в состав специализированной смеси"
      },
      "children1to3": {
        "ageFrom": 1,
        "ageTo": 3,
        "unit": "лет",
        "dose": {
          "min": 100,
          "max": 150,
          "unit": "мг/сут"
        }
      },
      "children3to10": {
        "ageFrom": 3,
        "ageTo": 10,
        "unit": "лет",
        "dose": {
          "min": 150,
          "max": 250,
          "unit": "мг/сут"
        }
      },
      "adolescentsAndAdults": {
        "ageFrom": 10,
        "ageTo": 100,
        "unit": "лет",
        "dose": {
          "min": 250,
          "max": 500,
          "unit": "мг/сут"
        }
      }
    },

    "precautions": [
      "Использовать очищенные препараты (без EPA, без LCT)",
      "Избегать рыбьего жира с высоким содержанием LCT",
      "Предпочтительны препараты из водорослей (без LCT)"
    ],

    "monitoring": {
      "parameters": ["осмотр офтальмолога", "электроретинография"],
      "frequency": "ежегодно"
    }
  },

  "coq10": {
    "description": "Коэнзим Q10 (убихинон)",
    "tradenames": ["Кудесан", "CoQ10", "Убихинон"],
    "forms": ["капсулы", "капли", "раствор"],

    "indications": {
      "required": {
        "diagnoses": ["GA2"],
        "description": "Обязательно при GA2 (особенно мутации ETFDH). Улучшает перенос электронов в митохондриях."
      },
      "recommended": {
        "diagnoses": ["VLCAD", "LCHAD", "TFP"],
        "description": "Рекомендуется как антиоксидантная поддержка"
      }
    },

    "dosing": {
      "GA2": {
        "children": {
          "doseMin": 10,
          "doseMax": 30,
          "unit": "мг/кг/сут",
          "maxDailyDose": 400,
          "maxUnit": "мг/сут",
          "note": "Высокие дозы при ETFDH мутациях"
        },
        "adults": {
          "doseMin": 200,
          "doseMax": 600,
          "unit": "мг/сут",
          "note": "Может потребоваться до 1000 мг/сут при тяжёлых формах"
        }
      },
      "supportive": {
        "children": {
          "doseMin": 5,
          "doseMax": 15,
          "unit": "мг/кг/сут",
          "maxDailyDose": 300,
          "maxUnit": "мг/сут"
        },
        "adults": {
          "doseMin": 100,
          "doseMax": 300,
          "unit": "мг/сут"
        }
      }
    },

    "monitoring": {
      "parameters": ["клинический ответ", "мышечная сила", "креатинкиназа"],
      "note": "Оценить ответ через 4-8 недель терапии"
    }
  },

  "glycine": {
    "description": "Глицин",
    "indications": {
      "optional": {
        "diagnoses": ["GA2"],
        "description": "Связывание токсичных метаболитов"
      }
    },
    "dosing": {
      "dose": {
        "min": 150,
        "max": 300,
        "unit": "мг/кг/сут"
      },
      "frequency": "3 раза в день"
    }
  },

  "bezafibrate": {
