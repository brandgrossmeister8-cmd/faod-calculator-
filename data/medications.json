  },

  "triheptanoin": {
    "description": "Тригептаноин (C7 жирная кислота)",
    "tradenames": ["Dojolvi"],
    "forms": ["масло для приёма внутрь"],

    "indications": {
      "experimental": {
        "diagnoses": ["LCHAD", "TFP", "VLCAD"],
        "description": "Анаплеротическая терапия (восполнение цикла Кребса)"
      }
    },

    "dosing": {
      "dose": {
        "min": 25,
        "max": 35,
        "unit": "% от калорийности"
      },
      "note": "Вводится постепенно, замещая часть MCT. Доступность ограничена."
    },

    "availability": "Не зарегистрирован в РФ. Возможен ввоз по жизненным показаниям."
  },

  "emergencyProtocol": {
    "description": "Экстренная терапия при метаболическом кризе",
    "medications": [
      {
        "name": "Глюкоза 10%",
        "route": "в/в",
        "rate": {
          "infants": "10-12 мг/кг/мин",
          "children": "8-10 мг/кг/мин",
          "adolescents": "5-8 мг/кг/мин"
        },
        "target": "гликемия > 4.0 ммоль/л"
      },
      {
        "name": "L-карнитин",
        "route": "в/в",
        "dose": "100-200 мг/кг/сут",
        "contraindications": ["VLCAD_SYMPTOMATIC", "LCHAD", "TFP"]
      },
      {
        "name": "Натрия бикарбонат",
        "route": "в/в",
        "indication": "При метаболическом ацидозе (pH < 7.2)",
        "dose": "1-2 мэкв/кг"
      }
    ],

    "hospitalIndications": [
      "Невозможность перорального питания",
      "Рвота более 2 раз",
      "Отказ от еды более 4-6 часов",
      "Гипогликемия < 3.0 ммоль/л",
      "Нарушение сознания",
      "Судороги",
      "Выраженная мышечная слабость"
    ]
  },

